# Public base URL where desktop release files will be hosted.
# The app will look under:
# - ${APP_UPDATE_BASE_URL}/darwin/arm64/RELEASES.json
# - ${APP_UPDATE_BASE_URL}/win32/x64/RELEASES
APP_UPDATE_BASE_URL=https://downloads.example.com/csn-media-bridge

# Optional notes written into the macOS RELEASES.json entry for this build.
APP_UPDATE_RELEASE_NOTES=Desktop update with auto-update support enabled.

# Enable macOS code signing when a Developer ID Application certificate is installed locally.
APPLE_SIGN_ENABLED=true

# Optional explicit signing identity. Leave blank if you want codesign to infer the installed identity.
APPLE_SIGN_IDENTITY=Developer ID Application: Your Company, Inc. (TEAMID1234)

# Preferred notarization strategy: a notarytool keychain profile.
# Create one with:
# xcrun notarytool store-credentials "csn-media-bridge-notary" --apple-id <id> --team-id <team> --password <app-specific-password>
APPLE_KEYCHAIN_PROFILE=csn-media-bridge-notary

# Alternate notarization strategy: Apple ID + app-specific password.
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=TEAMID1234

# Alternate notarization strategy: App Store Connect API key.
# APPLE_API_KEY=/absolute/path/AuthKey_ABC123XYZ.p8
# APPLE_API_KEY_ID=ABC123XYZ
# APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
