{
  "name": "csn-media-bridge",
  "productName": "CSN Media Bridge",
  "version": "1.0.0",
  "description": "Cross-platform Electron ingest station for automated VOD transcoding and cloud sync.",
  "main": ".vite/build/main.js",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "electron-forge start",
    "start": "electron-forge start",
    "build": "electron-forge package",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "release:check": "pnpm run typecheck && pnpm run lint",
    "make:release": "pnpm run release:check && pnpm run make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "keywords": [],
  "author": "jamalgillis",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "41.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.4.5",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@videojs/react": "10.0.0-beta.15",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.3",
    "convex": "^1.34.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  }
}
